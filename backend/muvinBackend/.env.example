#  MUVIN BACKEND - Variáveis de ambiente
#  Copie este arquivo para .env e preencha os valores
#  cp .env.example .env

# Banco de dados (PostgreSQL)
# ------------------------------------------------------------
POSTGRES_DB=muvin
POSTGRES_USER=           # ex: muvin_user
POSTGRES_PASSWORD=       # escolha uma senha forte

# ------------------------------------------------------------
# JWT - Autenticação
# Mínimo 32 caracteres, use uma string aleatória segura
# Gere com: openssl rand -base64 32
JWT_SECRET_KEY=

# ------------------------------------------------------------
# Email (SMTP)
# Use uma conta Gmail com App Password habilitado
# Como gerar App Password: https://myaccount.google.com/apppasswords
EMAIL_USUARIO=           # ex: seuemail@gmail.com
EMAIL_SENHA=             # App Password de 16 caracteres (ex: "abcd efgh ijkl mnop")

# ------------------------------------------------------------
# DigitalOcean Spaces (armazenamento de fotos)
# Crie um Space em: https://cloud.digitalocean.com/spaces
# Gere as chaves em: API > Spaces Keys
DO_ACCESS_KEY=
DO_SECRET_KEY=

# ------------------------------------------------------------
# Seed - Conta de administrador criada na primeira execução
SEED_SENHA=              # senha do admin inicial (mude após o primeiro login)

# ------------------------------------------------------------
# Porta exposta pelo backend (opcional, padrão: 5000)
# ------------------------------------------------------------
# BACKEND_PORT=5000
